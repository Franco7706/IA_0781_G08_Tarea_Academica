 la izquierda.\")\n","except Exception as e:\n","    # Si hay error de tokens, intentamos con una codificación alternativa\n","    df = pd.read_csv(ruta_archivo, decimal=',', encoding='latin1')\n","    print(\"Archivo cargado con codificación alternativa.\")\n","\n","print(\"Forma antes de preprocesamiento: \",df.shape)\n","\n","# --- 2. INSPECCIÓN GENERAL ---\n","print(\"--- ESTRUCTURA DEL DATASET ---\")\n","print(df.info()) # Muestra tipos de datos y conteo de no nulos\n","\n","print(\"\\n--- VALORES FALTANTES (NULOS) ---\")\n","null_counts = df.isnull().sum()\n","\n","with pd.option_context('display.max_rows', None, 'display.max_columns', None, 'display.expand_frame_repr', False):\n","    print(null_counts[null_counts > 0]) # Solo muestra columnas con nulos\n","\n","\n","# --- 3. ESTADÍSTICAS DESCRIPTIVAS ---\n","print(\"\\n--- RESUMEN ESTADÍSTICO (Numéricas) ---\")\n","# Esto te ayudará a ver si 'promedio' o los scores tienen sentido\n","print(df.describe())\n","\n","# -- ANÁLISIS DE ALGUNOS OUTLIERS ---\n","# Gráfico de caja para ver outliers en el promedio y scores clave\n","variables_analizar = ['promedio', 'metas', 'expectance', 'habilidades_sociales']\n","\n","plt.figure(figsize=(15, 5))\n","for i, var in enumerate(variables_analizar):\n","    plt.subplot(1, 4, i+1)\n","    sns.boxplot(y=df[var])\n","    plt.title(f'Outliers en {var}')\n","\n","plt.tight_layout()\n","plt.show()\n","\n","\n","# --- 4. VISUALIZACIÓN DE DISTRIBUCIONES ---\n","# --- 1. CONFIGURACIÓN DE VARIABLES ---\n","# Corregimos el nombre para que sea consistente en todo el código\n","psyc_vars = ['habilidades_sociales', 'soporte_social', 'planear', 'metas',\n","             'internal_control', 'expectance', 'value', 'hopes', 'fears',\n","             'exploration', 'commitment', 'desercion']\n","\n","# --- 2. INSPECCIÓN Y LIMPIEZA RÁPIDA ---\n","print(\"--- VALORES FALTANTES ---\")\n","print(df[psyc_vars].isnull().sum())\n","\n","# Opcional: Si quieres eliminar filas con NaN en estas variables específicas para que el heatmap no falle\n","# df = df.dropna(subset=psyc_vars)\n","\n","# --- 3. VISUALIZACIÓN DE DISTRIBUCIONES ---\n","sns.set(style=\"whitegrid\")\n","\n","# A. Distribución de la variable objetivo\n","plt.figure(figsize=(8, 5))\n","sns.countplot(x='desercion', data=df, palette='viridis')\n","plt.title('Distribución de la Intención de Deserción')\n","plt.show()\n","\n","# B. Mapa de Calor de Correlaciones (CORREGIDO)\n","plt.figure(figsize=(12, 10))\n","\n","# Filtramos el dataframe solo con las variables de interés y nos aseguramos de que sean numéricas\n","df_corr = df[psyc_vars].apply(pd.to_numeric, errors='coerce')\n","\n","# Calculamos la correlación\n","corr = df_corr.corr()\n","\n","sns.heatmap(corr, annot=True, cmap='coolwarm', fmt=\".2f\", linewidths=0.5)\n","plt.title('Mapa de Calor de Correlaciones Psicológicas (Herrera et al., 2025)')\n","plt.show()\n","\n","# C. Análisis por Tipo de Universidad\n","plt.figure(figsize=(10, 6))\n","# Verificamos si 'tipo_universidad' existe antes de graficar\n","if 'tipo_universidad' in df.columns:\n","    sns.boxplot(x='tipo_universidad', y='desercion', data=df)\n","    plt.title('Intención de Deserción por Tipo de Universidad')\n","else:\n","    print(\"La columna 'tipo_universidad' no se encuentra en el dataset.\")\n","plt.show()"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":1000},"id":"pWvlKmyHt7Vo","executionInfo":{"status":"ok","timestamp":1783029084362,"user_tz":300,"elapsed":6862,"user":{"displayName":"KALEF AZAEL MANDUJANO VALLEJOS","userId":"16905477293702538355"}},"outputId":"8c05ac7c-c1f6-4ee8-9f64-f3d86495faec"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Archivo cargado exitosamente.\n","Forma antes de preprocesamiento:  (768, 88)\n","--- ESTRUCTURA DEL DATASET ---\n","<class 'pandas.core.frame.DataFrame'>\n","RangeIndex: 768 entries, 0 to 767\n","Data columns (total 88 columns):\n"," #   Column                    Non-Null